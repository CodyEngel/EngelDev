---
layout: base.liquid
---
<article class="container-narrow section post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
      {% if tags.size > 0 %}
        {% render "partials/tag-list.liquid", tags: tags %}
      {% endif %}
    </div>
  </header>
  <div class="prose">
    {{ content }}
  </div>
  <nav class="post-footer" aria-label="Post">
    <a href="/blog/">&larr; All posts</a>
  </nav>
</article>
