---
layout: base.liquid
---
{% render "partials/hero.liquid", site: site %}

{% if collections.featuredProjects != empty %}
<section class="section container">
  <div class="section-head" data-reveal>
    <h2>Projects</h2>
    <a class="section-link" href="/projects/">All projects</a>
  </div>
  <div class="grid">
    {% for project in collections.featuredProjects %}
      {% render "partials/project-card.liquid", project: project %}
    {% endfor %}
  </div>
</section>
{% endif %}

<section class="section container">
  <div class="section-head" data-reveal>
    <h2>Recent posts</h2>
    <a class="section-link" href="/blog/">All posts</a>
  </div>
  <div class="post-list">
    {% for post in collections.posts limit: 6 %}
      {% assign revealDelay = forloop.index0 | times: 70 %}
      {% render "partials/post-card.liquid", post: post, lead: forloop.first, delay: revealDelay %}
    {% endfor %}
  </div>
</section>
